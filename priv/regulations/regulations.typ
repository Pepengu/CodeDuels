#set page(
  paper: "a4",
  margin: (x: 2cm, y: 2cm),
)

#set text(
  font: "Linux Libertine",
  size: 12pt,
)

#let tname = sys.inputs.at("tournament_name", default: none)
#let rounds = sys.inputs.at("rounds", default: none)
#let round_time = sys.inputs.at("round_time", default: none)
#let intermission = sys.inputs.at("intermission_time", default: none)
#let problems = sys.inputs.at("problems_per_round", default: none)
#let penalty = sys.inputs.at("penalty", default: none)
#let scores_str = sys.inputs.at("scores", default: none)

#let fmt_time(seconds) = {
  if seconds != none {
    str(int(seconds) / 60)
  } else {
    "N"
  }
}

#let fmt_rounds(val) = {
  if val != none { val } else { "N" }
}

#let fmt_num(val) = {
  if val != none { str(val) } else { "N" }
}

#let fmt_scores(val) = {
  if val != none {
    val.split(",").map(s => str(int(s.trim()))).join(", ")
  } else {
    "N"
  }
}

#let title = if tname != none [
  Положение о соревновании #tname
] else [
  Положение о соревновании
]

#align(center)[
  #text(size: 18pt, strong(title))
]

#v(0.5cm)

#let preamble = if tname != none [
  Соревнование *#tname* проводится для студентов петергофских факультетов СПбГУ.
] else [
  Настоящее положение является общим для всех соревнований. Отдельные параметры могут различаться в зависимости от конкретного турнира. Значения, помеченные символом *N*, определяются правилами конкретного соревнования и указываются на его странице.
]

#preamble

#v(0.5cm)

== 1. Общие положения

#if tname != none [
  1.1. Соревнование *#tname* (далее — соревнование) проводится для студентов петергофских факультетов СПбГУ.
] else [
  1.1. Соревнование проводится для студентов петергофских факультетов СПбГУ.
]

1.2. Организатор соревнования --- кружок спортивного программирования ПМ-ПУ.

1.3. Дата и место проведения объявляются отдельным объявлением.

1.4. Языки программирования: GNU C++ 17, GNU C++ 23, Visual C++, Python 3, PyPy 3, Java, Go.

== 2. Формат соревнования

2.1. Соревнование состоит из *#fmt_rounds(rounds)* раундов.

2.2. Каждый раунд длится *#fmt_time(round_time)* минут.

2.3. Между раундами предусмотрен перерыв *#fmt_time(intermission)* минут.

2.4. В каждом раунде предлагается *#fmt_num(problems)* задач.

2.5. Участники решают задачи индивидуально.

== 3. Система оценивания

3.1. Все задачи доступны с начала раунда. За задачу получает очки только первый участник, верно её решивший.

3.2. Первый участник, верно решивший задачу, получает очки за неё (First AC). Баллы за задачи: *#fmt_scores(scores_str)*.

3.3. За неверную попытку начисляется штрафное время в размере *#fmt_num(penalty)* минут.

3.4. Штрафное время за неверную попытку не влияет на счёт внутри одного раунда.

3.5. В дуэли победитель получает 1 очко, при ничьей оба участника получают 0,5 очка, при поражении — 0 очков. Победитель соревнования определяется по Швейцарской системе на основе суммы очков за все дуэли.

3.6. При равном количестве очков победителем считается участник с наибольшим суммарным количеством баллов за задачи. При равенстве баллов за задачи с меньшим суммарным штрафным временем.

== 4. Шаблоны

4.1. Участникам разрешено использовать пренабранный код объёмом до 1 КБ.

4.2. Шаблон может содержать:
- Функции-помощники работы с вводом-выводом
- Макросы для ускорения печати. Например `#define vi vector<int>`

4.3. Запрещено использование алгоритмов и структур данных в пренабранном коде.

4.4. Участник желающий использовать шаблон должен показать его организаторам или волонтёрам перед началом соревнования. Если участник этого не сделал и в его шаблоне будет обнаружено нарушение, то мера наказания будет решаться организаторами на месте.

== 5. Правила поведения

5.1. Во время раунда участник не имеет права использовать интернет, мобильный телефон и любые устройства связи.

5.2. Использование искусственного интеллекта (AI) для генерации кода или помощи в решении задач запрещено.

5.3. Работа выполняется индивидуально. Обсуждение с другими участниками запрещено.

5.4. За нарушение правил участник дисквалифицируется.

5.5. Решения принимаются организаторами и являются окончательными.

== 6. Награждение

6.1. Участники, занявшие 1-е, 2-е и 3-е места, награждаются медалями.

6.2. Порядок награждения определяется результатами соревнования.
